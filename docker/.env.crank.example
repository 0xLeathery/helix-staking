# Crank service environment — Docker Compose variant
# Copy to .env.crank (gitignored) and fill in secrets
#
# Key difference from services/crank/.env.example:
#   RPC_URL uses the Docker service name "validator" (not localhost)
#   because the crank container is on the same Compose network

# Required
RPC_URL=http://validator:8899
PROGRAM_ID=<your-program-id>
CRANK_KEYPAIR_JSON=[1,2,3,...,64]

# Optional
RPC_URL_FALLBACK=http://validator:8899
CLUSTER=localnet
SOL_BALANCE_THRESHOLD_SOL=0.1
HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/<TOKEN>
LOG_LEVEL=info
