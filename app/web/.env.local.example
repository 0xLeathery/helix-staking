# === Mainnet ===
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# === Devnet ===
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Direct public RPC (client-side, optional — falls back to /api/rpc proxy)
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# SECURITY NOTE: Never add secret keys or private keys to NEXT_PUBLIC_ prefixed vars.
# NEXT_PUBLIC_ vars are inlined into client JS bundles at build time and exposed to all users.
# NEXT_PUBLIC_TEST_WALLET_SECRET has been permanently removed (F-01 CRITICAL fix).

# === Push Notifications (Web Push / VAPID) ===
# Generate keys: npx web-push generate-vapid-keys
# Store the private key in the indexer's VAPID_PRIVATE_KEY env var.
# CRITICAL: Losing the private key invalidates ALL existing push subscriptions permanently.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# === NFT Badge Minting (Bubblegum V2) ===
# Created by running: npx ts-node scripts/setup-badge-collection.ts
# Both addresses are printed by the setup script after completion.
BADGE_COLLECTION_ADDRESS=YourBubblegumCollectionAddressHere
BADGE_MERKLE_TREE_ADDRESS=YourConcurrentMerkleTreeAddressHere
# JSON byte array of the badge authority keypair secret key (64 bytes)
# SECURITY: Keep this secret — this key can mint badges for any user.
BADGE_AUTHORITY_SECRET=[1,2,3,...,64]

# === Indexer URL ===
# URL of the running HELIX indexer service (used by server-side API routes)
# Falls back to http://localhost:3001 in development if not set
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
