# ============================================================
# HELIX Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real secrets.
#
# For Vercel deployment: set these in Project Settings -> Environment Variables
# Only set REQUIRED vars in Production. DEV/TEST vars must NOT be set in Production.
# ============================================================

# ============================================================
# REQUIRED — Server-side secrets (never prefixed with NEXT_PUBLIC_)
# Set in Vercel dashboard for Production environment
# ============================================================

# Helius RPC endpoint — used by /api/rpc proxy, /api/badges/mint, /api/badges/claimed
# Get your key at: https://dashboard.helius.dev
# Mainnet: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Devnet:  https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Badge authority keypair — 64-byte secret key as JSON array
# Created by: npx ts-node scripts/setup-badge-collection.ts
# SECURITY: This key can mint badges for ANY user — treat as production secret
# Format: JSON array of bytes, e.g. [1,2,3,...,64]
BADGE_AUTHORITY_SECRET=[1,2,3,...,64]

# Bubblegum collection public key — from setup-badge-collection.ts output
BADGE_COLLECTION_ADDRESS=YourBubblegumCollectionAddressHere

# Concurrent Merkle Tree public key — from setup-badge-collection.ts output
BADGE_MERKLE_TREE_ADDRESS=YourConcurrentMerkleTreeAddressHere

# ============================================================
# REQUIRED — Client-side (NEXT_PUBLIC_ = inlined at build time)
# These are visible to all users in the browser JS bundle
# ============================================================

# Indexer service URL — used by all pages fetching protocol stats
# Production: https://indexer.yourdomain.com
# Development: http://localhost:3001
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# Web Push VAPID public key — for push notification subscriptions
# Generate: npx web-push generate-vapid-keys
# Store the PRIVATE key in the indexer's VAPID_PRIVATE_KEY env var
# CRITICAL: Losing the private key invalidates ALL existing push subscriptions
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ============================================================
# OPTIONAL — Client-side
# ============================================================

# Direct Solana RPC URL for client-side connections
# If NOT set: client uses /api/rpc proxy (RECOMMENDED for production — includes rate limiting)
# If SET: client connects directly to RPC (bypasses proxy rate limit protection)
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# ============================================================
# DEV/TEST ONLY — must NOT be set in Vercel Production
# ============================================================

# E2E test wallet keypair — enables /api/test-wallet route
# When absent, /api/test-wallet returns 404 (safe by design)
# TEST_WALLET_SECRET=[1,2,3,...,64]

# Dev flag — bypass wallet connection requirement in UI
# NEXT_PUBLIC_SKIP_WALLET_CHECK=true
